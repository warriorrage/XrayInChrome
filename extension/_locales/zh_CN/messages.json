  "help_step1_title": { "message": "第一步：获取并启动向导" },
  "help_step1_desc": { "message": "访问 <a href='https://github.com/warriorrage/XrayInChrome/tree/main/native-host' target='_blank' style='color:#1a73e8;text-decoration:underline;'>GitHub</a> 下载并运行 安装向导 'xray-bridge.exe'。" },
  "help_step2_title": { "message": "第二步：确认意图" },
  "help_step2_desc": { "message": "在弹出的对话框中选择 'Yes' 以开始安装或更新桥接程序。" },
  "help_step3_title": { "message": "第三步：关联核心" },
  "help_step3_desc": { "message": "在文件选择对话框中，选中你电脑上的 'xray.exe' 核心文件并点击确定。此操作会将桥接程序注册到 Windows 注册表，使 Chrome 浏览器获得调用xray的权限。" },
  "help_step4_title": { "message": "第四步：连接验证" },
  "help_step4_desc": { "message": "重启浏览器并点击 Xray in Chrome 插件按钮打开侧边栏。此时插件会自动启动桥接程序，确认 'xray-bridge.exe' 状态变为 '运行中'，表明通信链路已打通。" },
  "help_step5_title": { "message": "第五步：配置节点" },
  "help_step5_desc": { "message": "在 '节点设置' 页面导入代理节点，并点击选中一个目标节点（状态显示为 ✅），将其设为活动配置。" },
  "help_step6_title": { "message": "第六步：启动核心" },
  "help_step6_desc": { "message": "在 '首页' 右上角开启运行开关。此操作将正式启动 'xray.exe' 核心进程。确认状态变为 '运行中' 且日志无报错，即启动成功。" },
  "help_step7_title": { "message": "第七步：接管流量" },
  "help_step7_desc": { "message": "在 '系统设置' 中勾选 '接管此浏览器代理' 并点击 '应用'，浏览器流量将正式通过 Xray 转发。" },

