{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.1.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": ["nativeMessaging", "sidePanel", "storage", "proxy"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Xray Manager",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
